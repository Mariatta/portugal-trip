---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import HotelCard from '../components/HotelCard.astro';
import RestaurantCard from '../components/RestaurantCard.astro';
import DayCard from '../components/DayCard.astro';
import MapSection from '../components/MapSection.astro';
import type { CityData } from '../data/types';

const { city } = Astro.props as { city: CityData };
const base = import.meta.env.BASE_URL;

const prev: Record<string, string|null> = { porto: null, lisbon: 'porto', aveiro: 'lisbon' };
const next: Record<string, string|null> = { porto: 'lisbon', lisbon: 'aveiro', aveiro: null };
---

<Layout title={city.name} description={`${city.nights} nights in ${city.name}, Portugal — hotels, restaurants & day-by-day itinerary`}>
  <Nav active={city.slug} />

  <!-- City Hero -->
  <header class="city-hero" style={`--city-accent: ${city.accentColor}`}>
    <div class="city-hero-inner">
      <p class="city-eyebrow">{city.dates} · {city.nights} nights</p>
      <h1 class="city-title">{city.name}</h1>
      <p class="city-tagline">{city.tagline}</p>
    </div>
    <div class="city-hero-accent-bar" style={`background: ${city.accentColor}`}></div>
  </header>

  <main>
    <!-- Overview Map -->
    <section class="section">
      <div class="container">
        <div class="section-label">Overview</div>
        <h2 class="section-title">{city.name} at a glance</h2>
        <p class="section-intro">Attractions, hotels and restaurants — all on one map.</p>
        <MapSection
          mapCenter={city.mapCenter}
          mapZoom={city.mapZoom}
          mapPoints={city.mapPoints}
          accentColor={city.accentColor}
        />
      </div>
    </section>

    <!-- Itinerary -->
    <section class="section section-alt">
      <div class="container">
        <div class="section-label">Day by Day</div>
        <h2 class="section-title">The itinerary</h2>
        <div class="days-grid">
          {city.days.map(d => (
            <DayCard day={d} accentColor={city.accentColor} />
          ))}
        </div>

        {city.transport && (
          <div class="transport-bar" style={`border-left-color: ${city.accentColor}; background: ${city.accentColor}0D`}>
            <span class="transport-icon">🚆</span>
            <p class="transport-text">{city.transport}</p>
          </div>
        )}
      </div>
    </section>

    <!-- Hotels -->
    <section class="section">
      <div class="container">
        <div class="section-label">Where to Stay</div>
        <h2 class="section-title">Hotels in {city.name}</h2>
        <p class="section-intro">Four options across budget ranges — from splurge-worthy waterfront stays to excellent value picks.</p>
        <div class="cards-grid">
          {city.hotels.map(h => (
            <HotelCard hotel={h} />
          ))}
        </div>
      </div>
    </section>

    <!-- Restaurants -->
    <section class="section section-alt">
      <div class="container">
        <div class="section-label">Where to Eat</div>
        <h2 class="section-title">Restaurants in {city.name}</h2>
        <p class="section-intro">Family-tested picks from formal dinners to the best value lunches. Ratings from verified reviews.</p>
        <div class="cards-grid">
          {city.restaurants.map(r => (
            <RestaurantCard restaurant={r} />
          ))}
        </div>
      </div>
    </section>

    <!-- Navigation between cities -->
    <section class="section city-nav-section">
      <div class="container">
        <div class="city-nav">
          {prev[city.slug] ? (
            <a href={`${base}${prev[city.slug]}/`} class="city-nav-btn city-nav-prev">
              ← {prev[city.slug]!.charAt(0).toUpperCase() + prev[city.slug]!.slice(1)}
            </a>
          ) : (
            <a href={base} class="city-nav-btn city-nav-prev">← Overview</a>
          )}
          {next[city.slug] ? (
            <a href={`${base}${next[city.slug]}/`} class="city-nav-btn city-nav-next">
              {next[city.slug]!.charAt(0).toUpperCase() + next[city.slug]!.slice(1)} →
            </a>
          ) : (
            <a href={base} class="city-nav-btn city-nav-next">Back to Overview →</a>
          )}
        </div>
      </div>
    </section>
  </main>

  <footer>
    <div class="container footer-inner">
      <p class="footer-text">🇵🇹 Portugal Family Trip · August 2026</p>
      <p class="footer-sub">Built with Astro · Hosted on GitHub Pages</p>
    </div>
  </footer>
</Layout>

<style>
  .city-hero {
    padding: 5rem 2rem 4rem;
    text-align: center;
    border-bottom: 1px solid var(--cream-dark);
    position: relative;
    background: radial-gradient(ellipse 60% 50% at 50% 60%, rgba(0,0,0,0.03), transparent);
  }
  .city-hero-inner { max-width: 700px; margin: 0 auto; }
  .city-eyebrow {
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--city-accent);
    margin-bottom: 1rem;
  }
  .city-title {
    font-family: var(--font-display);
    font-size: clamp(4rem, 12vw, 8rem);
    font-weight: 300;
    color: var(--ink);
    line-height: 0.9;
    margin-bottom: 1.25rem;
    letter-spacing: -0.02em;
  }
  .city-tagline {
    font-size: 1.05rem;
    color: var(--ink-muted);
    font-weight: 300;
    line-height: 1.6;
  }
  .city-hero-accent-bar {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 40px;
    height: 3px;
    border-radius: 2px;
  }

  .section { padding: 5rem 2rem; }
  .section-alt { background: white; }
  .container { max-width: 1100px; margin: 0 auto; }
  .section-label {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.75rem;
  }
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 300;
    color: var(--ink);
    margin-bottom: 1rem;
  }
  .section-intro {
    font-size: 1rem;
    color: var(--ink-muted);
    max-width: 600px;
    margin-bottom: 2.5rem;
    line-height: 1.75;
  }

  .days-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .transport-bar {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    border-left: 3px solid;
    border-radius: 0 var(--radius) var(--radius) 0;
  }
  .transport-icon { font-size: 1.1rem; flex-shrink: 0; }
  .transport-text { font-size: 0.875rem; color: var(--ink-muted); }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
  }

  .city-nav-section { padding: 3rem 2rem; background: white; border-top: 1px solid var(--cream-dark); }
  .city-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }
  .city-nav-btn {
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--ink-muted);
    padding: 0.75rem 1.5rem;
    border: 1px solid var(--cream-dark);
    border-radius: var(--radius);
    background: var(--cream);
    transition: background 0.2s, color 0.2s;
  }
  .city-nav-btn:hover { background: var(--cream-dark); color: var(--ink); }

  footer { border-top: 1px solid var(--cream-dark); padding: 2rem; }
  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    text-align: center;
  }
  .footer-text { font-family: var(--font-display); font-size: 1rem; color: var(--ink-muted); }
  .footer-sub { font-size: 0.75rem; color: var(--ink-faint); }

  @media (max-width: 600px) {
    .city-hero { padding: 4rem 1.5rem 3rem; }
    .section { padding: 3rem 1.25rem; }
    .days-grid, .cards-grid { grid-template-columns: 1fr; }
    .city-nav { flex-direction: column; }
    .city-nav-btn { width: 100%; text-align: center; }
  }
</style>
