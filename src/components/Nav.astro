---
const { active = '' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<nav>
  <div class="nav-inner">
    <a class="nav-brand" href={base}>🇵🇹 Portugal 2026</a>
    <ul class="nav-links">
      <li><a href={base} class={active === 'home' ? 'active' : ''}>Overview</a></li>
      <li><a href={`${base}porto/`} class={active === 'porto' ? 'active' : ''}>Porto</a></li>
      <li><a href={`${base}lisbon/`} class={active === 'lisbon' ? 'active' : ''}>Lisbon</a></li>
      <li><a href={`${base}aveiro/`} class={active === 'aveiro' ? 'active' : ''}>Aveiro</a></li>
      <li><a href={`${base}checklist/`} class={active === 'checklist' ? 'active' : ''}>Checklist</a></li>
      <li><a href={`${base}about/`} class={active === 'about' ? 'active' : ''}>About</a></li>
    </ul>
  </div>
</nav>
